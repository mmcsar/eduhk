# MMC Immo - Configuration Supabase
# Copiez ce fichier en .env et remplissez les valeurs

# URL de votre projet Supabase
# Trouvez-le dans: Project Settings > API > Project URL
VITE_SUPABASE_URL=https://votre-projet.supabase.co

# Clé publique anonyme
# Trouvez-la dans: Project Settings > API > Project API keys > anon public
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optionnel: Clé de service (NE JAMAIS EXPOSER CÔTÉ CLIENT)
# Utilisez-la uniquement côté serveur pour les opérations admin
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
