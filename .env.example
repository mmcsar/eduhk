# TMSA Environment Variables Template
# Copy this file to .env.local and fill in your values

# ========== DATABASE ==========
MONGODB_URI=mongodb://localhost:27017/tmsa
POSTGRES_URI=postgresql://user:password@localhost:5432/tmsa
REDIS_URL=redis://localhost:6379

# ========== AUTHENTICATION ==========
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ========== API KEYS ==========
API_GATEWAY_KEY=tmsa-gateway-key-production
INTERNAL_SERVICE_KEY=tmsa-internal-service-key

# ========== PAYMENT PROVIDERS ==========
# CinetPay (West/Central Africa)
CINETPAY_API_KEY=your-cinetpay-api-key
CINETPAY_SITE_ID=your-cinetpay-site-id
CINETPAY_SECRET_KEY=your-cinetpay-secret-key
CINETPAY_WEBHOOK_SECRET=your-cinetpay-webhook-secret

# Stripe (International)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ========== FILE STORAGE ==========
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-west-1
AWS_S3_BUCKET=tmsa-documents

# Cloudinary (alternative)
CLOUDINARY_CLOUD_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-cloudinary-key
CLOUDINARY_API_SECRET=your-cloudinary-secret

# ========== NOTIFICATIONS ==========
# Twilio (SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=tmsa-app
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@tmsa-app.iam.gserviceaccount.com

# SendGrid (Email)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@tmsa.africa

# ========== TRACKING ==========
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
MAPBOX_ACCESS_TOKEN=your-mapbox-token

# ========== MONITORING ==========
SENTRY_DSN=your-sentry-dsn
GRAFANA_URL=http://localhost:3001
PROMETHEUS_URL=http://localhost:9090

# ========== APPLICATION ==========
NODE_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:3000
MOBILE_DEEP_LINK=tmsa://

# ========== CORS ==========
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# ========== RATE LIMITING ==========
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========== KAFKA (Event Streaming) ==========
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=tmsa-services
KAFKA_GROUP_ID=tmsa-consumer-group

# ========== ELASTICSEARCH (Logs & Search) ==========
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme
