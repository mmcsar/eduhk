{
  "expo": {
    "name": "TMSA Driver",
    "slug": "tmsa-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "tmsa",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tmsa.driver",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "TMSA needs your location to track missions in real-time",
        "NSLocationWhenInUseUsageDescription": "TMSA needs your location to track missions",
        "NSCameraUsageDescription": "TMSA needs camera access to scan QR codes and upload documents",
        "NSPhotoLibraryUsageDescription": "TMSA needs access to your photos to upload documents"
      }
    },
    "android": {
      "package": "com.tmsa.driver",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow TMSA to use your location to track missions."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2563eb"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
