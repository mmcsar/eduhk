{
  "name": "@tmsa/monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "TMSA - Africa Transport Hub | Enterprise Monorepo",
  "workspaces": [
    "apps/*",
    "services/*",
    "libs/*"
  ],
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "docker:up": "docker-compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infra/docker/docker-compose.yml down",
    "k8s:deploy": "kubectl apply -f infra/kubernetes/",
    "db:migrate": "pnpm --filter @tmsa/api-gateway run migrate",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "husky": "^9.0.0",
    "prettier": "^3.2.0",
    "turbo": "^1.12.0",
    "typescript": "^5.3.0"
  },
  "author": "TMSA Tech Team",
  "license": "PROPRIETARY"
}
