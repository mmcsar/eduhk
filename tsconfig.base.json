{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@tmsa/types": ["libs/types/src"],
      "@tmsa/utils": ["libs/utils/src"],
      "@tmsa/configs": ["libs/configs/src"],
      "@tmsa/sdk": ["libs/sdk/src"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".next"]
}
